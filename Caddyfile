# Snappeal local reverse proxy
# - `/` → the Next.js dev server running on the host at :3001
# - `/wiki/*` → the MkDocs wiki container at wiki:8000 (strip prefix)
# - `/docs` → redirect to /wiki/ for convenience
#
# Access locally at http://localhost:8080
# Cloudflare tunnel can also point here for a single public URL.

:80 {
    encode gzip

    # Friendly redirect
    @docs path /docs /docs/
    redir @docs /wiki/ permanent

    # Wiki under /wiki/*
    handle_path /wiki/* {
        reverse_proxy wiki:8000
    }

    # Everything else → Next.js dev server on the host.
    # Must match the dev port in apps/web/package.json (`next dev --port 3001`)
    # and the cloudflared target in docker-compose.yml. When the dev port moved
    # 3000 → 3001 (commit 6f7db81) this proxy was left on 3000, so the named
    # Cloudflare tunnel (snappeal.theailab.dev) fronting this Caddy 502'd.
    handle {
        reverse_proxy host.docker.internal:3001
    }
}
